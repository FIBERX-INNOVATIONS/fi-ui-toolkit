{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Node",
        "outDir": "./dist",
        "rootDir": "./",
        "baseUrl": ".",
        "strict": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "allowJs": true,
         "declaration": true,
        "types": ["Node"],
        "lib": ["ES6", "DOM"],
        "typeRoots": ["./node_modules/@types", "./version_3/types"],
        "paths": {
            "@ui_v3/*": ["version_3/*"],
        },
        "experimentalDecorators": true
    },
    "include": [
      "version_3/**/*.vue",
      "version_3/**/*.ts",
      "vite-env.d.ts"  
    ],
    "exclude": ["node_modules", "dist", "test"]
}