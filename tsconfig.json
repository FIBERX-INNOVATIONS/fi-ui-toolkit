{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "outDir": "./dist",
        "rootDir": "./src",
        "strict": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "allowJs": true,
        "declaration": true,
        "types": [
            "Node"
        ],
        "lib": [
            "ES6",
            "DOM"
        ],
        "typeRoots": [
            "./node_modules/@types",
            "./src/version_3/types"
        ],
        "baseUrl": ".",
        "paths": {
            "@v2/*": ["src/version_2/*"]
        },
        "experimentalDecorators": true,
        "ignoreDeprecations": "6.0"
    },
    "include": [
        "src/**/*.vue",
        "src/**/*.ts",
        "vite-env.d.ts"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "test",
        "src/version_3/props_builder"
    ]
}
