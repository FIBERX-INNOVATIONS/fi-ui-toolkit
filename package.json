{
    "name": "fi-ui-toolkit",
    "version": "4.0.23",
    "description": "fi-ui-toolkit is a customizable Vue 3 component library designed to provide reusable, styled, and configurable UI elements across multiple Vue applications. It helps standardize UI structure, simplify development, and promote consistency across your projects.",
    "homepage": "https://github.com/Ojooh/fi-ui-toolkit#readme",
    "bugs": {
        "url": "https://github.com/Ojooh/fi-ui-toolkit/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Ojooh/fi-ui-toolkit.git"
    },
    "license": "ISC",
    "author": "David Matt-Ojo",
    "type": "commonjs",
    "main": "app.ts",
    "scripts": {
        "format": "prettier --write src --ignore-unknown",
        "format:check": "prettier --check src --ignore-unknown",
        "lint": "eslint src && npm run typecheck",
        "lint:fix": "eslint src --fix",
        "precommit": "lint-staged && npm run typecheck",
        "prepare": "git config core.hooksPath .githooks",
        "test": "echo \"Error: no test specified\" && exit 1",
        "typecheck": "vue-tsc --noEmit",
        "update-dependencies": "node scripts/update-dependencies.js"
    },
    "dependencies": {
        "@vuepic/vue-datepicker": "^14.0.0",
        "axios": "^1.17.0",
        "dayjs": "^1.11.21",
        "mitt": "^3.0.1",
        "qrcode": "^1.5.4",
        "vue-router": "^5.1.0",
        "vue3-tel-input": "^1.0.4"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^25.9.2",
        "eslint": "^10.4.1",
        "eslint-plugin-vue": "^10.9.2",
        "lint-staged": "^17.0.7",
        "prettier": "^3.8.4",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.61.0",
        "vite": "^8.0.16",
        "vue-eslint-parser": "^10.4.1",
        "vue-tsc": "^3.3.4"
    },
    "peerDependencies": {
        "vue": "^3.5.35"
    },
    "overrides": {
        "postcss": "^8.5.10"
    },
    "lint-staged": {
        "src/**/*.{ts,vue,js,cjs,mjs}": [
            "prettier --write",
            "eslint --fix"
        ],
        "src/**/*.{json,md,css}": "prettier --write"
    },
    "allowScripts": {
        "core-js@3.49.0": true,
        "fsevents@2.3.3": true,
        "vue-demi@0.14.10": true
    }
}
